{
  "env": { "node": true, "es2021": true, "jest": true },
  "extends": "eslint:recommended",
  "parserOptions": { "ecmaVersion": "latest" },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "error",
    "semi": ["error", "always"],
    "quotes": ["error", "single"],
    "no-trailing-spaces": "error"
  }
}