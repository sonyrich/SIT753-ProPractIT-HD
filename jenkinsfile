pipeline {
    agent any

    environment {
        APP_NAME        = 'taskmanager-api'
        DOCKER_IMAGE    = 'taskmanager-api'
        SONAR_PROJECT   = 'taskmanager-api'
        STAGING_PORT    = '3001'
        PROD_PORT       = '3000'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    triggers { githubPush() }

    stages {

        stage('Build') {
            steps {
                echo "=== BUILD STAGE ==="
                sh 'npm ci'
                sh """
                    docker build \
                        --target production \
                        -t ${DOCKER_IMAGE}:${BUILD_NUMBER} \
                        -t ${DOCKER_IMAGE}:latest \
                        --label "build=${BUILD_NUMBER}" \
                        --label "git-commit=${GIT_COMMIT}" \
                        .
                """
            }
            post {
                success {
                    sh 'docker inspect ${DOCKER_IMAGE}:${BUILD_NUMBER} > docker-inspect.json'
                    archiveArtifacts artifacts: 'docker-inspect.json', fingerprint: true
                    echo "✅ Build stage passed"
                }
                failure { echo "❌ Build stage failed" }
            }
        }

        stage('Test') {
            steps {
                echo "=== TEST STAGE ==="
                sh 'npm test'
            }
            post {
                always {
                    publishHTML(target: [
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'coverage/lcov-report',
                        reportFiles: 'index.html',
                        reportName: 'Test Coverage Report'
                    ])
                }
                success { echo "✅ All tests passed" }
                failure {
                    echo "❌ Tests failed - blocking pipeline"
                    error("Tests failed. Pipeline stopped.")
                }
            }
        }

        stage('Code Quality') {
            steps {
                echo "=== CODE QUALITY STAGE ==="
                withSonarQubeEnv('SonarQube') {
                    sh """
                        sonar-scanner \
                            -Dsonar.projectKey=${SONAR_PROJECT} \
                            -Dsonar.projectName="${APP_NAME}" \
                            -Dsonar.projectVersion=1.0.${BUILD_NUMBER} \
                            -Dsonar.sources=src \
                            -Dsonar.tests=tests \
                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                            -Dsonar.exclusions=node_modules/**,coverage/**,logs/**
                    """
                }
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
            post {
                success { echo "✅ Code quality gate passed" }
                failure { echo "⚠️ Code quality issues found" }
            }
        }

        stage('Security') {
            steps {
                echo "=== SECURITY STAGE ==="
                sh """
                    trivy image \
                        --format table \
                        --severity LOW,MEDIUM,HIGH,CRITICAL \
                        --output trivy-report.txt \
                        --exit-code 0 \
                        ${DOCKER_IMAGE}:${BUILD_NUMBER}
                    cat trivy-report.txt
                    trivy image --severity CRITICAL --exit-code 1 --quiet \
                        ${DOCKER_IMAGE}:${BUILD_NUMBER} || echo "CRITICAL vulnerabilities found - review required"
                """
                sh 'npm audit --audit-level=high || true'
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-report.txt', allowEmptyArchive: true
                }
                success { echo "✅ Security scan passed" }
                failure { echo "⚠️ Security vulnerabilities found - see trivy-report.txt" }
            }
        }

        stage('Deploy') {
            steps {
                echo "=== DEPLOY STAGE (Staging) ==="
                sh 'docker-compose -f docker-compose.staging.yml down --remove-orphans || true'
                sh "IMAGE_TAG=${BUILD_NUMBER} docker-compose -f docker-compose.staging.yml up -d"
                sh """
                    for i in \$(seq 1 12); do
                        STATUS=\$(curl -s -o /dev/null -w "%{http_code}" http://localhost:${STAGING_PORT}/health/ready || echo "000")
                        if [ "\$STATUS" = "200" ]; then
                            echo "✅ Staging is healthy"
                            exit 0
                        fi
                        echo "Attempt \$i: status=\$STATUS, retrying..."
                        sleep 5
                    done
                    echo "❌ Staging health check failed"
                    exit 1
                """
            }
            post {
                success { echo "✅ Deployed to staging: http://localhost:${STAGING_PORT}" }
                failure {
                    echo "❌ Staging deployment failed"
                    sh 'docker-compose -f docker-compose.staging.yml logs --tail=50 || true'
                }
            }
        }

        stage('Release') {
            when { branch 'main' }
            steps {
                echo "=== RELEASE STAGE (Production) ==="
                sh "docker tag ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:release-${BUILD_NUMBER}"
                sh """
                    git config user.email "jenkins@ci.local"
                    git config user.name "Jenkins CI"
                    git tag -a v1.0.${BUILD_NUMBER} -m "Release v1.0.${BUILD_NUMBER}"
                    git push origin v1.0.${BUILD_NUMBER} || echo "Git push skipped"
                """
                input message: "Deploy v1.0.${BUILD_NUMBER} to PRODUCTION?",
                      ok: "Deploy to Production",
                      submitter: "admin"
                sh 'docker-compose -f docker-compose.staging.yml down || true'
                sh "IMAGE_TAG=${BUILD_NUMBER} docker-compose -f docker-compose.production.yml up -d"
                sh """
                    for i in \$(seq 1 12); do
                        STATUS=\$(curl -s -o /dev/null -w "%{http_code}" http://localhost:${PROD_PORT}/health/ready || echo "000")
                        if [ "\$STATUS" = "200" ]; then
                            echo "✅ Production is healthy"
                            exit 0
                        fi
                        sleep 5
                    done
                    echo "❌ Production health check failed - rolling back"
                    docker-compose -f docker-compose.production.yml down
                    exit 1
                """
            }
            post {
                success { echo "✅ Release v1.0.${BUILD_NUMBER} live in production" }
                failure { echo "❌ Production release failed" }
            }
        }

        stage('Monitoring') {
            steps {
                echo "=== MONITORING STAGE ==="
                sh """
                    PROM=\$(curl -s -o /dev/null -w "%{http_code}" http://localhost:9090/-/healthy || echo "000")
                    GRAF=\$(curl -s -o /dev/null -w "%{http_code}" http://localhost:3002/api/health || echo "000")
                    echo "Prometheus: \$PROM | Grafana: \$GRAF"
                    HEALTH=\$(curl -s http://localhost:${PROD_PORT}/health)
                    echo "Health: \$HEALTH"
                    echo \$HEALTH | grep -q 'uptime' && echo "✅ Uptime metric OK"
                    echo \$HEALTH | grep -q 'memory' && echo "✅ Memory metric OK"
                """
                sh """
                    curl -s -X POST \
                        -H 'Content-type: application/json' \
                        --data '{"text":"🚀 TaskManager v1.0.${BUILD_NUMBER} deployed successfully!"}' \
                        \${SLACK_WEBHOOK_URL:-https://hooks.slack.com/DUMMY} || echo "Slack webhook not configured"
                """
            }
            post {
                success { echo "✅ Monitoring verified" }
                failure { echo "⚠️ Monitoring check failed" }
            }
        }
    }

    post {
        always {
            echo "Pipeline #${BUILD_NUMBER} finished: ${currentBuild.currentResult}"
            cleanWs()
        }
        success { echo "🎉 All stages passed! App live at http://localhost:${PROD_PORT}" }
        failure { echo "💥 Pipeline failed — check stage logs above" }
    }
}